<?xml version="1.0" encoding="utf-8"?>
<!--  res/layout/activity_main.xml  -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <!-- ── Decorative top arc ── -->
    <View
        android:id="@+id/arcTop"
        android:layout_width="420dp"
        android:layout_height="420dp"
        android:background="@drawable/circle_accent_top"
        android:alpha="0.12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="-160dp"
        android:layout_marginEnd="-160dp"/>

    <!-- ── Decorative bottom arc ── -->
    <View
        android:id="@+id/arcBottom"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:background="@drawable/circle_accent_bottom"
        android:alpha="0.10"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="-120dp"
        android:layout_marginBottom="-100dp"/>

    <!-- ── Icon container ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/iconCard"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/accent_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvAppName"
        android:layout_marginBottom="28dp"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🧠"
            android:textSize="44sp"/>

    </androidx.cardview.widget.CardView>

    <!-- ── App name ── -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QuizMaster"
        android:textColor="@color/text_primary"
        android:textSize="38sp"
        android:fontFamily="@font/poppins_bold"
        android:letterSpacing="0.02"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iconCard"
        app:layout_constraintBottom_toTopOf="@id/tvTagline"/>

    <!-- ── Tagline ── -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="Challenge your mind.\nProve your knowledge."
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintBottom_toTopOf="@id/statsRow"/>

    <!-- ── Stats row ── -->
    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTagline"
        app:layout_constraintBottom_toTopOf="@id/btnStartQuiz">

        <!-- Stat 1 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/stat_card_bg"
            android:padding="16dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textColor="@color/accent_primary"
                android:textSize="28sp"
                android:fontFamily="@font/poppins_bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Questions"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"/>
        </LinearLayout>

        <!-- Stat 2 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/stat_card_bg"
            android:padding="16dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡"
                android:textSize="28sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Fire"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"/>
        </LinearLayout>

        <!-- Stat 3 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/stat_card_bg"
            android:padding="16dp"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆"
                android:textSize="28sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Earn Score"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ── CTA Button ── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartQuiz"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="Start Quiz"
        android:textSize="17sp"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_bold"
        android:letterSpacing="0.04"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="40dp"
        app:backgroundTint="@color/accent_primary"
        app:cornerRadius="16dp"
        app:elevation="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statsRow"
        app:layout_constraintBottom_toTopOf="@id/tvFooter"/>

    <!-- ── Footer note ── -->
    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap the button or it'll ask you automatically 😉"
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        android:fontFamily="@font/poppins_regular"
        android:layout_marginBottom="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>