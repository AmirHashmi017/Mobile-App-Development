<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.QuizApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>
    <style name="QuizDialogTheme" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="android:background">@color/bg_card</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/DialogPositiveBtn</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogNegativeBtn</item>
    </style>

    <style name="DialogPositiveBtn" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="DialogNegativeBtn" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!--  NEW: tints the TextInputLayout outline & label to match the dark dialog  -->
    <style name="NameInputTheme" parent="ThemeOverlay.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <style name="Theme.QuizApp" parent="Base.Theme.QuizApp" />
</resources>