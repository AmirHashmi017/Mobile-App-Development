<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Backgrounds -->
    <color name="bg_deep">#0F172A</color>         <!-- deep navy -->
    <color name="bg_card">#1E293B</color>          <!-- slate card -->
    <color name="bg_card_stroke">#334155</color>   <!-- subtle border -->

    <!-- Accent -->
    <color name="accent_primary">#6366F1</color>   <!-- indigo -->
    <color name="accent_light">#818CF8</color>
    <color name="accent_glow">#312E81</color>

    <!-- Text -->
    <color name="text_primary">#F1F5F9</color>
    <color name="text_secondary">#94A3B8</color>
    <color name="text_hint">#475569</color>

    <!-- Misc -->
    <color name="white">#FFFFFF</color>
    <color name="colorPrimary">#6366F1</color>
    <color name="colorPrimaryVariant">#4338CA</color>
    <color name="colorOnPrimary">#FFFFFF</color>
</resources>


