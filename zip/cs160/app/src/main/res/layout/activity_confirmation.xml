<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/hero_bg"
        android:paddingTop="40dp"
        android:paddingBottom="30dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <LinearLayout
            android:id="@+id/successIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_centerHorizontal="true"
            android:layout_alignParentTop="true"
            android:background="@drawable/success_circle"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textColor="@color/white"
                android:textSize="36sp"
                android:fontFamily="sans-serif-bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/successIcon"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registration Confirmed!"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Your event registration has been submitted successfully."
                android:textColor="@color/white_80"
                android:textSize="14sp"
                android:textAlignment="center"
                android:lineSpacingMultiplier="1.5"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Confirmation ID Badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/confirmation_card_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎫"
                    android:textSize="24sp"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONFIRMATION ID"
                        android:textColor="#E94560"
                        android:textSize="10sp"
                        android:letterSpacing="0.15"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/tvConfirmationId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#SEM-2024-0001"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Participant Details Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PARTICIPANT DETAILS"
                    android:textColor="#E94560"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp"/>

                <!-- Profile Image + Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:id="@+id/ivConfirmImage"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:background="@drawable/logo_circle"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:padding="16dp"
                        android:contentDescription="Profile photo"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvConfirmName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-bold"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvConfirmGender"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#E94560"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Phone Row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                        android:text="Phone" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvDetailPhone" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="@color/white" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#2A4A6A" android:layout_marginBottom="12dp"/>

                <!-- Email Row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                        android:text="Email" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvDetailEmail" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="@color/white" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#2A4A6A" android:layout_marginBottom="12dp"/>

                <!-- Event Type Row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                        android:text="Event Type" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvDetailEventType" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="@color/white" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#2A4A6A" android:layout_marginBottom="12dp"/>

                <!-- Date Row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                        android:text="Event Date" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvDetailDate" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="@color/white" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Registration Summary Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REGISTRATION SUMMARY"
                    android:textColor="#E94560"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                        android:text="Name" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvSummaryName" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="@color/white" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                        android:text="Phone" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvSummaryPhone" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="@color/white" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                        android:text="Email" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvSummaryEmail" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="@color/white" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                        android:text="Event Type" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvSummaryEventType" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="@color/white" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                        android:text="Event Date" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvSummaryDate" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="@color/white" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                        android:text="Gender" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvSummaryGender" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="@color/white" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Back to Home Button -->
            <Button
                android:id="@+id/btnBackHome"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="@drawable/btn_primary"
                android:text="Back to Home"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:fontFamily="sans-serif-bold"
                android:elevation="6dp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>