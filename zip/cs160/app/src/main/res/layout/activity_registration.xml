<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/hero_bg"
        android:padding="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="24dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/card_bg"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="@color/white"
            android:padding="8dp"
            android:contentDescription="Back"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Registration"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:fontFamily="sans-serif-bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fill in your details below"
                android:textColor="@color/white_80"
                android:textSize="12sp"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- Scrollable Form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbarThumbVertical="@drawable/btn_primary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Personal Info Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERSONAL INFORMATION"
                    android:textColor="#E94560"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp"/>

                <!-- Full Name -->
                <TextView style="@style/LabelStyle" android:text="FULL NAME *"/>
                <EditText
                    android:id="@+id/etFullName"
                    style="@style/InputStyle"
                    android:hint="Enter your full name"
                    android:inputType="textPersonName"
                    android:imeOptions="actionNext"
                    android:layout_marginBottom="16dp"/>

                <!-- Phone Number -->
                <TextView style="@style/LabelStyle" android:text="PHONE NUMBER *"/>
                <EditText
                    android:id="@+id/etPhone"
                    style="@style/InputStyle"
                    android:hint="Enter phone number"
                    android:inputType="phone"
                    android:imeOptions="actionNext"
                    android:layout_marginBottom="16dp"/>

                <!-- Email Address -->
                <TextView style="@style/LabelStyle" android:text="EMAIL ADDRESS *"/>
                <EditText
                    android:id="@+id/etEmail"
                    style="@style/InputStyle"
                    android:hint="Enter email address"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionDone"
                    android:layout_marginBottom="0dp"/>
            </LinearLayout>

            <!-- Event Details Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EVENT DETAILS"
                    android:textColor="#E94560"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp"/>

                <!-- Event Type Spinner -->
                <TextView style="@style/LabelStyle" android:text="EVENT TYPE *"/>
                <Spinner
                    android:id="@+id/spinnerEventType"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/spinner_bg"
                    android:popupBackground="#1A2E4A"
                    android:layout_marginBottom="16dp"/>

                <!-- Event Date -->
                <TextView style="@style/LabelStyle" android:text="EVENT DATE *"/>
                <Button
                    android:id="@+id/btnSelectDate"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/date_btn_bg"
                    android:text="📅  Select Event Date"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:textAlignment="textStart"
                    android:gravity="center_vertical|start"
                    android:paddingStart="16dp"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="0dp"/>
            </LinearLayout>

            <!-- Gender Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GENDER *"
                    android:textColor="#E94560"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp"/>

                <RadioGroup
                    android:id="@+id/radioGroupGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radioMale"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Male"
                        android:textColor="@color/white"
                        android:buttonTint="#E94560"
                        android:textSize="14sp"
                        android:gravity="center_vertical"
                        android:fontFamily="sans-serif"/>

                    <RadioButton
                        android:id="@+id/radioFemale"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Female"
                        android:textColor="@color/white"
                        android:buttonTint="#E94560"
                        android:textSize="14sp"
                        android:gravity="center_vertical"
                        android:fontFamily="sans-serif"/>

                    <RadioButton
                        android:id="@+id/radioOther"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Other"
                        android:textColor="@color/white"
                        android:buttonTint="#E94560"
                        android:textSize="14sp"
                        android:gravity="center_vertical"
                        android:fontFamily="sans-serif"/>
                </RadioGroup>
            </LinearLayout>

            <!-- Profile Image Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PROFILE PHOTO"
                    android:textColor="#E94560"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivProfileImage"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="@drawable/image_upload_bg"
                        android:src="@android:drawable/ic_menu_camera"
                        android:tint="#E94560"
                        android:scaleType="centerCrop"
                        android:padding="16dp"
                        android:contentDescription="Profile image"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Upload Your Photo"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JPG, PNG supported\nMax 5MB"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginBottom="12dp"/>

                        <Button
                            android:id="@+id/btnUploadImage"
                            android:layout_width="130dp"
                            android:layout_height="38dp"
                            android:background="@drawable/btn_primary"
                            android:text="Choose Photo"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:elevation="0dp"
                            android:stateListAnimator="@null"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Terms Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <CheckBox
                    android:id="@+id/checkboxTerms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="I accept the Terms and Conditions"
                    android:textColor="@color/white"
                    android:buttonTint="#E94560"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="By registering, you agree to our event policies and privacy terms. Your data will be handled securely."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="36dp"/>
            </LinearLayout>

            <!-- Submit Button -->
            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="@drawable/btn_primary"
                android:text="Submit Registration"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.05"
                android:elevation="6dp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>